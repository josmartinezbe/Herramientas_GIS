  .slider-row { display: flex; align-items: center; gap: 10px; margin: .75rem 0; font-size: 13px; color: var(--text2); }
  .slider-row label { min-width: 140px; }
  .slider-row input[type=range] { flex: 1; accent-color: var(--green); }
  .slider-row .readout { min-width: 50px; text-align: right; font-weight: 500; color: var(--text); }
  @media print {
    .slider-row { display: none; }
    .page { padding: 1rem; }
  }
  .summary-box { background: var(--bg2); border-radius: var(--radius-lg); padding: 1.25rem; border: 0.5px solid var(--border); margin-top: 2rem; }
  .summary-title { font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--text3); margin-bottom: .75rem; }
</style>
