  }
  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); line-height: 1.7; font-size: 15px; }
  .page { max-width: 760px; margin: 0 auto; padding: 2rem 2rem 5rem; }
  .hero { padding: 2.5rem 0 2rem; border-bottom: 1px solid var(--border); margin-bottom: 1.5rem; }
  .hero-label { font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--text3); margin-bottom: .5rem; }
  .hero-title { font-family: 'Lora', serif; font-size: 30px; font-weight: 500; line-height: 1.2; margin-bottom: .75rem; }
  .hero-sub { font-size: 14px; color: var(--text2); max-width: 580px; }
  .toc { background: var(--bg2); border-radius: var(--radius-lg); padding: 1rem 1.25rem; margin-bottom: 2rem; border: 0.5px solid var(--border); }
  .toc-title { font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--text3); margin-bottom: .6rem; }
