      --border: rgba(255,255,255,0.12); --border2: rgba(255,255,255,0.22);
      --blue: #5B9FE5; --blue-bg: #0c2a47; --blue-dark: #B5D4F4;
      --green: #3DC49A; --green-bg: #0a2e22; --green-dark: #9FE1CB;
      --red: #F09595; --red-bg: #3a1414; --red-dark: #F7C1C1;
